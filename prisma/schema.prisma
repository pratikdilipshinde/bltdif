generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id          String       @id @default(cuid())
  email       String       @unique
  firstname   String?
  lastname    String?
  role        Role         @default(USER)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orders      Order[]
  userProfile UserProfile?
  shopOrders  ShopOrder[]

  @@map("Profile")
}

model UserProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  phoneNumber     String?
  currentAddress  String?
  shippingAddress String?
  city            String?
  state           String?
  zipCode         String?
  country         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("UserProfile")
}

/// OLD PRODUCT TABLE
/// Keeping untouched for now
model Product {
  id           BigInt   @id @default(autoincrement())
  sku          String   @unique
  name         String
  type         String
  category     String
  description  String?
  material     String?
  features     String?
  careGuide    String?  @map("care_guide")
  delivery     String?
  count        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  price        Decimal? @db.Decimal
  imageUrl     String?  @map("image_url")
  availability Boolean? @default(true)
  images       String[] @default([])

  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  shippingAddress String?
  note            String?
  totalAmount     Float       @default(0)
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]

  @@map("Order")
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  productName  String
  productImage String?
  quantity     Int      @default(1)
  price        Float    @default(0)
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("OrderItem")
}

model CatalogCategory {
  id        BigInt           @id @default(autoincrement())
  code      String           @unique
  name      String
  sortOrder Int              @default(0) @map("sort_order")
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  products  CatalogProduct[]

  @@map("catalog_categories")
}

model CatalogSize {
  id        BigInt                  @id @default(autoincrement())
  code      String                  @unique
  label     String
  sortOrder Int                     @default(0) @map("sort_order")
  isActive  Boolean                 @default(true) @map("is_active")
  createdAt DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  variants  CatalogProductVariant[]

  @@map("catalog_sizes")
}

model CatalogProduct {
  id               BigInt                  @id @default(autoincrement())
  productCode      String                  @unique @map("product_code")
  slug             String                  @unique
  name             String
  categoryId       BigInt                  @map("category_id")
  productType      String?                 @map("product_type")
  shortDescription String?                 @map("short_description")
  description      String?
  material         String?
  features         String?
  careGuide        String?                 @map("care_guide")
  deliveryInfo     String?                 @map("delivery_info")
  brand            String                  @default("BLTDIF")
  status           String                  @default("DRAFT")
  basePrice        Decimal                 @map("base_price") @db.Decimal(10, 2)
  compareAtPrice   Decimal?                @map("compare_at_price") @db.Decimal(10, 2)
  currencyCode     String                  @default("USD") @map("currency_code")
  isFeatured       Boolean                 @default(false) @map("is_featured")
  isNewArrival     Boolean                 @default(false) @map("is_new_arrival")
  seoTitle         String?                 @map("seo_title")
  seoDescription   String?                 @map("seo_description")
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  images           CatalogProductImage[]
  variants         CatalogProductVariant[]
  category         CatalogCategory         @relation(fields: [categoryId], references: [id], onUpdate: NoAction)
  shopOrderItems   ShopOrderItem[]
  stockMovements   StockMovement[]

  @@index([categoryId], map: "idx_catalog_products_category_id")
  @@index([isFeatured], map: "idx_catalog_products_featured")
  @@index([status], map: "idx_catalog_products_status")
  @@map("catalog_products")
}

model CatalogProductVariant {
  id                BigInt                @id @default(autoincrement())
  productId         BigInt                @map("product_id")
  sku               String                @unique
  sizeId            BigInt?               @map("size_id")
  color             String?
  colorCode         String?               @map("color_code")
  price             Decimal?              @db.Decimal(10, 2)
  compareAtPrice    Decimal?              @map("compare_at_price") @db.Decimal(10, 2)
  stockQuantity     Int                   @default(0) @map("stock_quantity")
  reservedQuantity  Int                   @default(0) @map("reserved_quantity")
  lowStockThreshold Int                   @default(5) @map("low_stock_threshold")
  weightGrams       Int?                  @map("weight_grams")
  isActive          Boolean               @default(true) @map("is_active")
  isDefault         Boolean               @default(false) @map("is_default")
  barcode           String?
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  images            CatalogProductImage[]
  product           CatalogProduct        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  size              CatalogSize?          @relation(fields: [sizeId], references: [id], onUpdate: NoAction)
  shopOrderItems    ShopOrderItem[]
  stockMovements    StockMovement[]

  @@unique([productId, sizeId, color], map: "uq_catalog_variant")
  @@index([productId], map: "idx_catalog_variants_product_id")
  @@index([sizeId], map: "idx_catalog_variants_size_id")
  @@map("catalog_product_variants")
}

model CatalogProductImage {
  id        BigInt                 @id @default(autoincrement())
  productId BigInt?                @map("product_id")
  variantId BigInt?                @map("variant_id")
  imageUrl  String                 @map("image_url")
  altText   String?                @map("alt_text")
  sortOrder Int                    @default(0) @map("sort_order")
  isPrimary Boolean                @default(false) @map("is_primary")
  createdAt DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  product   CatalogProduct?        @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variant   CatalogProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([productId], map: "idx_catalog_images_product_id")
  @@index([variantId], map: "idx_catalog_images_variant_id")
  @@map("catalog_product_images")
}

model ShopOrder {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber     String            @unique @map("order_number")
  userId          String?           @map("user_id")
  customerName    String            @map("customer_name")
  customerEmail   String            @map("customer_email")
  customerPhone   String?           @map("customer_phone")
  shippingName    String?           @map("shipping_name")
  shippingPhone   String?           @map("shipping_phone")
  addressLine1    String            @map("address_line_1")
  addressLine2    String?           @map("address_line_2")
  city            String
  state           String
  zipCode         String            @map("zip_code")
  country         String            @default("USA")
  subtotalAmount  Decimal           @default(0) @map("subtotal_amount") @db.Decimal(10, 2)
  shippingAmount  Decimal           @default(0) @map("shipping_amount") @db.Decimal(10, 2)
  discountAmount  Decimal           @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxAmount       Decimal           @default(0) @map("tax_amount") @db.Decimal(10, 2)
  totalAmount     Decimal           @default(0) @map("total_amount") @db.Decimal(10, 2)
  currencyCode    String            @default("USD") @map("currency_code")
  orderStatus     ShopOrderStatus   @default(PENDING) @map("order_status")
  paymentStatus   ShopPaymentStatus @default(PENDING) @map("payment_status")
  paymentProvider String?           @map("payment_provider")
  paymentId       String?           @map("payment_id")
  paymentOrderId  String?           @map("payment_order_id")
  trackingNumber  String?           @map("tracking_number")
  courierName     String?           @map("courier_name")
  trackingUrl     String?           @map("tracking_url")
  customerNote    String?           @map("customer_note")
  adminNote       String?           @map("admin_note")
  paidAt          DateTime?         @map("paid_at") @db.Timestamptz(6)
  shippedAt       DateTime?         @map("shipped_at") @db.Timestamptz(6)
  deliveredAt     DateTime?         @map("delivered_at") @db.Timestamptz(6)
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  items           ShopOrderItem[]
  user            Profile?          @relation(fields: [userId], references: [id], onUpdate: NoAction)
  stockMovements  StockMovement[]

  @@index([userId], map: "idx_shop_orders_user_id")
  @@index([customerEmail], map: "idx_shop_orders_customer_email")
  @@index([orderStatus], map: "idx_shop_orders_order_status")
  @@index([paymentStatus], map: "idx_shop_orders_payment_status")
  @@index([createdAt(sort: Desc)], map: "idx_shop_orders_created_at")
  @@map("shop_orders")
}

model ShopOrderItem {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String                @map("order_id") @db.Uuid
  productId    BigInt                @map("product_id")
  variantId    BigInt                @map("variant_id")
  productCode  String                @map("product_code")
  sku          String
  productName  String                @map("product_name")
  categoryCode String?               @map("category_code")
  sizeCode     String?               @map("size_code")
  sizeLabel    String?               @map("size_label")
  color        String?
  imageUrl     String?               @map("image_url")
  quantity     Int
  unitPrice    Decimal               @map("unit_price") @db.Decimal(10, 2)
  totalPrice   Decimal               @map("total_price") @db.Decimal(10, 2)
  createdAt    DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  order        ShopOrder             @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product      CatalogProduct        @relation(fields: [productId], references: [id], onUpdate: NoAction)
  variant      CatalogProductVariant @relation(fields: [variantId], references: [id], onUpdate: NoAction)

  @@index([orderId], map: "idx_shop_order_items_order_id")
  @@index([productId], map: "idx_shop_order_items_product_id")
  @@index([variantId], map: "idx_shop_order_items_variant_id")
  @@map("shop_order_items")
}

model StockMovement {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId     BigInt                @map("product_id")
  variantId     BigInt                @map("variant_id")
  orderId       String?               @map("order_id") @db.Uuid
  movementType  StockMovementType     @map("movement_type")
  quantity      Int
  previousStock Int?                  @map("previous_stock")
  newStock      Int?                  @map("new_stock")
  reason        String?
  note          String?
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  order         ShopOrder?            @relation(fields: [orderId], references: [id], onUpdate: NoAction)
  product       CatalogProduct        @relation(fields: [productId], references: [id], onUpdate: NoAction)
  variant       CatalogProductVariant @relation(fields: [variantId], references: [id], onUpdate: NoAction)

  @@index([productId], map: "idx_stock_movements_product_id")
  @@index([variantId], map: "idx_stock_movements_variant_id")
  @@index([orderId], map: "idx_stock_movements_order_id")
  @@index([createdAt(sort: Desc)], map: "idx_stock_movements_created_at")
  @@map("stock_movements")
}

enum ShopOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShopPaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  RESERVED
  RELEASED
  SOLD
  CANCELLED
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Role {
  USER
  ADMIN
}
